# API
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/flowpilot

# AI (optional — required only for POST /ai/review)
# vLLM OpenAI-compatible endpoint
VLLM_URL=http://127.0.0.1:8000/v1/chat/completions

# Notifications (optional) — Slack Incoming Webhook for reminder delivery
SLACK_WEBHOOK_URL=

# Overdue SLA threshold in seconds (demo default 30; use e.g. 3600 for 1 hour in production)
SLA_SECONDS=30
# Frontend copy of the same threshold (must be set at build time)
NEXT_PUBLIC_SLA_SECONDS=30

# Web
NEXT_PUBLIC_API_URL=http://localhost:3000
